# =====================================================================
# AI 模拟面试系统 — 配置模板
# =====================================================================
# 使用方法：
#   1. 复制本文件为 application-local.yml（本地开发）或通过环境变量注入（生产）
#   2. 填入真实密钥
#   3. application-local.yml 已在 .gitignore 中，不会被提交
#
# 启动方式：
#   本地开发：./mvnw spring-boot:run -Dspring-boot.run.profiles=local
#   生产环境：通过环境变量注入 + -Dspring.profiles.active=prod
# =====================================================================

spring:
  datasource:
    # 数据库连接（可选，默认 localhost:3306/interview）
    # url: jdbc:mysql://localhost:3306/interview?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true&useUnicode=true&characterEncoding=UTF-8
    # username: root
    password: YOUR_MYSQL_PASSWORD          # 必填

  data:
    redis:
      # host: 127.0.0.1
      # port: 6379
      password: YOUR_REDIS_PASSWORD        # 必填

jwt:
  secret: YOUR_JWT_SECRET_AT_LEAST_32_BYTES   # 必填，≥32 字节随机字符串

ai:
  api-key: sk-YOUR_DEEPSEEK_KEY              # 必填，DeepSeek API Key

baidu:
  speech:
    api-key: YOUR_BAIDU_SPEECH_API_KEY       # 必填，百度语音 API Key
    secret-key: YOUR_BAIDU_SPEECH_SECRET_KEY # 必填，百度语音 Secret Key
